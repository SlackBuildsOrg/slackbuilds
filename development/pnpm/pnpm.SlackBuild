#  WARRANTIES, INCLUDING, BUT NOT LIMITED TO, THE IMPLIED WARRANTIES OF
#  MERCHANTABILITY AND FITNESS FOR A PARTICULAR PURPOSE ARE DISCLAIMED.  IN NO
#  EVENT SHALL THE AUTHOR BE LIABLE FOR ANY DIRECT, INDIRECT, INCIDENTAL,
#  SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,
#  PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS;
#  OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY,
#  WHETHER IN CONTRACT, STRICT LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR
#  OTHERWISE) ARISING IN ANY WAY OUT OF THE USE OF THIS SOFTWARE, EVEN IF
#  ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.

cd $(dirname $0) ; CWD=$(pwd)

PRGNAM=pnpm
VERSION=${VERSION:-11.13.1}
BUILD=${BUILD:-1}
TAG=${TAG:-_SBo}
PKGTYPE=${PKGTYPE:-tgz}

if [ -z "$ARCH" ]; then
  case "$( uname -m )" in
    i?86) ARCH=i586 ;;
    arm*) ARCH=arm ;;
       *) ARCH=$( uname -m ) ;;
  esac
fi

if [ ! -z "${PRINT_PACKAGE_NAME}" ]; then
  echo "$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
  exit 0
fi

TMP=${TMP:-/tmp/SBo}
PKG=$TMP/package-$PRGNAM
OUTPUT=${OUTPUT:-/tmp}

if [ "$ARCH" = "i586" ]; then
  LIBDIRSUFFIX=""
elif [ "$ARCH" = "i686" ]; then
  LIBDIRSUFFIX=""
elif [ "$ARCH" = "x86_64" ]; then
  LIBDIRSUFFIX="64"
elif [ "$ARCH" = "aarch64" ]; then
  LIBDIRSUFFIX="64"
else
  LIBDIRSUFFIX=""
fi

set -e

rm -rf $PKG
mkdir -p $TMP $PKG $OUTPUT
cd $TMP
rm -rf $PRGNAM-$VERSION
mkdir $PRGNAM-$VERSION
tar xvf $CWD/$PRGNAM-$VERSION.tgz -C $PRGNAM-$VERSION --strip-components 1
cd $PRGNAM-$VERSION
chown -R root:root .
find -L . \
 \( -perm 777 -o -perm 775 -o -perm 750 -o -perm 711 -o -perm 555 \
  -o -perm 511 \) -exec chmod 755 {} \; -o \
 \( -perm 666 -o -perm 664 -o -perm 640 -o -perm 600 -o -perm 444 \
  -o -perm 440 -o -perm 400 \) -exec chmod 644 {} \;

# disable self-update / update checking
cat << EOF | patch -p1
diff -Naur package.orig/dist/pnpm.mjs package/dist/pnpm.mjs
--- package.orig/dist/pnpm.mjs	1985-10-26 17:15:00.000000000 +0900
+++ package/dist/pnpm.mjs	2026-07-17 21:09:34.590723890 +0900
@@ -139462,6 +139462,7 @@
 // lib/checkForUpdates.js
 import path49 from "node:path";
 async function checkForUpdates(config2) {
+  return;
   const stateFile = path49.join(config2.stateDir, "pnpm-state.json");
   let state;
   try {
@@ -241685,6 +241686,7 @@
   });
 }
 async function handler33(opts3, params) {
+  throw new error_1.PnpmError("CANT_SELF_UPDATE_IN_PKGTOOLS", "You should update pnpm with the slackbuild");
   if (isExecutedByCorepack()) {
     throw new PnpmError("CANT_SELF_UPDATE_IN_COREPACK", "You should update pnpm with corepack");
   }
EOF

# don't need node-gyp
rm -rf dist/node-gyp-bin/ dist/node_modules/node-gyp/

# remove files for other platforms
rm -rf dist/vendor/*.exe
rm -rf dist/reflink*darwin*
rm -rf dist/reflink*win32*
find . -type f \( -name '*.cmd' -o -name '*.bat' -o -name '*.ps1' \) -delete

# remove sourcemaps, not needed
find . -type f -name '*.map' -delete

# remove hidden files and directories, not needed
find dist/node_modules -type f -name '.*' -delete
find dist/node_modules -type d -name '.*' -print0 | xargs -0 -n1 rm -rvf

# make sure we use the system node
sed -i 's,/usr/bin/env node,/usr/bin/node,g' bin/*

mkdir -p $PKG/usr/share/bash-completion/completions/
install -Dm644 dist/templates/completion.bash $PKG/usr/share/bash-completion/completions/$PRGNAM

mkdir -p $PKG/usr/share/zsh/site-functions/
install -Dm644 dist/templates/completion.zsh $PKG/usr/share/zsh/site-functions/_$PRGNAM

rm -rf dist/templates

install -Dm644 package.json -t $PKG/usr/lib$LIBDIRSUFFIX/node_modules/$PRGNAM
install -Dm755 bin/pnpm.mjs bin/pnpx.mjs -t $PKG/usr/lib$LIBDIRSUFFIX/node_modules/$PRGNAM/bin

cp -r dist $PKG/usr/lib$LIBDIRSUFFIX/node_modules/$PRGNAM/dist

mkdir -p $PKG/usr/bin
ln -sf ../lib$LIBDIRSUFFIX/node_modules/$PRGNAM/bin/pnpm.mjs $PKG/usr/bin/pnpm
ln -sf ../lib$LIBDIRSUFFIX/node_modules/$PRGNAM/bin/pnpx.mjs $PKG/usr/bin/pnpx

find $PKG -print0 | xargs -0 file | grep -e "executable" -e "shared object" | grep ELF \
  | cut -f 1 -d : | xargs strip --strip-unneeded 2> /dev/null || true

mkdir -p $PKG/usr/doc/$PRGNAM-$VERSION
cp -a \
  LICENSE README.md \
  $PKG/usr/doc/$PRGNAM-$VERSION
cat $CWD/$PRGNAM.SlackBuild > $PKG/usr/doc/$PRGNAM-$VERSION/$PRGNAM.SlackBuild

mkdir -p $PKG/install
cat $CWD/slack-desc > $PKG/install/slack-desc

cd $PKG
/sbin/makepkg -l y -c n $OUTPUT/$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE
