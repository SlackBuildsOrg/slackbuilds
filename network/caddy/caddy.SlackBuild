#  SPECIAL, EXEMPLARY, OR CONSEQUENTIAL DAMAGES (INCLUDING, BUT NOT LIMITED TO,
#  PROCUREMENT OF SUBSTITUTE GOODS OR SERVICES; LOSS OF USE, DATA, OR PROFITS;
#  OR BUSINESS INTERRUPTION) HOWEVER CAUSED AND ON ANY THEORY OF LIABILITY,
#  WHETHER IN CONTRACT, STRICT LIABILITY, OR TORT (INCLUDING NEGLIGENCE OR
#  OTHERWISE) ARISING IN ANY WAY OUT OF THE USE OF THIS SOFTWARE, EVEN IF
#  ADVISED OF THE POSSIBILITY OF SUCH DAMAGE.

cd $(dirname $0) ; CWD=$(pwd)

PRGNAM=caddy
VERSION=${VERSION:-2.11.2}
BUILD=${BUILD:-1}
TAG=${TAG:-_SBo}
PKGTYPE=${PKGTYPE:-tgz}
DIST=dist

CADDYUSER=${CADDYUSER:-caddy}
CADDYGROUP=${CADDYGROUP:-caddy}
CADDYUID=${CADDYUID:-398}
CADDYGID=${CADDYGID:-398}

if [ "$(grep ^$CADDYUSER: /etc/passwd)" = "" -o "$(grep ^$CADDYGROUP: /etc/group)" = "" ] ; then
    echo "  You must have a \"$CADDYGROUP\" group and user to run this script."
    echo "# groupadd --system -g $CADDYGID $CADDYGROUP"
    echo "# useradd --system -u $CADDYUID -g $CADDYGROUP -d /dev/null -s /bin/false $CADDYUSER"
    exit 1
fi

if [ -z "$ARCH" ]; then
  ARCH=$( uname -m )
fi

if [ "$ARCH" != "x86_64" ]; then
  echo "Package for $ARCH architecture is not available."
  exit 1
fi

if [ ! -z "${PRINT_PACKAGE_NAME}" ]; then
  echo "$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE"
  exit 0
fi

TMP=${TMP:-/tmp/SBo}
PKG=$TMP/package-$PRGNAM
OUTPUT=${OUTPUT:-/tmp}

set -e

rm -rf $PKG
mkdir -p $TMP $PKG $OUTPUT
cd $TMP
rm -rf $PRGNAM-$VERSION
tar xvf $CWD/$PRGNAM-$VERSION.tar.gz
tar xvf $CWD/$DIST-$VERSION.tar.gz

cd $PRGNAM-$VERSION
chown -R root:root .
find -L . \
 \( -perm 777 -o -perm 775 -o -perm 750 -o -perm 711 -o -perm 555 \
  -o -perm 511 \) -exec chmod 755 {} \; -o \
 \( -perm 666 -o -perm 664 -o -perm 640 -o -perm 600 -o -perm 444 \
  -o -perm 440 -o -perm 400 \) -exec chmod 644 {} \;

cd cmd/caddy/
go build

mkdir -p $PKG/var/lib/$PRGNAM
chown -R $CADDYUSER:$CADDYGROUP $PKG/var/lib/$PRGNAM

mkdir -p $PKG/usr/sbin
cp -a $PRGNAM $PKG/usr/sbin

mkdir -p $PKG/var/log/$PRGNAM
chown -R $CADDYUSER:$CADDYGROUP $PKG/var/log/$PRGNAM

mkdir -p $PKG/etc/$PRGNAM
mkdir -p $PKG/usr/share/$PRGNAM

mkdir -p $PKG/usr/doc/$PRGNAM-$VERSION
cd $TMP/$PRGNAM-$VERSION
cp -a LICENSE AUTHORS README.md $PKG/usr/doc/$PRGNAM-$VERSION
cat $CWD/$PRGNAM.SlackBuild > $PKG/usr/doc/$PRGNAM-$VERSION/$PRGNAM.SlackBuild
cat $CWD/README.SLACKWARE > $PKG/usr/doc/$PRGNAM-$VERSION/README.SLACKWARE

cd $TMP/$DIST-$VERSION
ls
cp -a config/Caddyfile $PKG/etc/$PRGNAM
cp -a scripts/completions/generate.sh $PKG/usr/doc/$PRGNAM-$VERSION
cp -a welcome/index.html $PKG/usr/share/$PRGNAM

chown -R :$CADDYGROUP $PKG/etc/$PRGNAM
find $PKG/usr/doc -type f -exec chmod 644 {} \;

mkdir -p $PKG/etc/rc.d
cat $CWD/rc.$PRGNAM > $PKG/etc/rc.d/rc.$PRGNAM.new

mkdir -p $PKG/install
cat $CWD/slack-desc > $PKG/install/slack-desc
cat $CWD/doinst.sh > $PKG/install/doinst.sh

cd $PKG
/sbin/makepkg -l y -c n $OUTPUT/$PRGNAM-$VERSION-$ARCH-$BUILD$TAG.$PKGTYPE
