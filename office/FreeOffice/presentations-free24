#!/bin/sh
# A script to run Presentations.
ext="${@##*.}"
shopt -s nocasematch
case "$ext" in
    "prs" ) /opt/FreeOffice2024/presentations -S\""$@"\";;
    "pps" ) /opt/FreeOffice2024/presentations -S\""$@"\";;
    "ppsx" ) /opt/FreeOffice2024/presentations -S\""$@"\";;
    * ) /opt/FreeOffice2024/presentations "$@";;
esac
